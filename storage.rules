rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    function signedIn() {
      return request.auth != null;
    }

    function familyDoc(familyId) {
      return firestore.get(/databases/(default)/documents/families/$(familyId));
    }

    function isFamilyMember(familyId) {
      return signedIn()
        && (
          familyDoc(familyId).data.ownerId == request.auth.uid
          || (
            familyDoc(familyId).data.memberIds is list
            && request.auth.uid in familyDoc(familyId).data.memberIds
          )
        );
    }

    function isFamilyEditor(familyId) {
      return signedIn()
        && (
          familyDoc(familyId).data.ownerId == request.auth.uid
          || familyDoc(familyId).data.memberRoles[request.auth.uid] == 'editor'
        );
    }

    function isSafeProfileImage(fileName) {
      return fileName.matches('^[A-Za-z0-9._-]{1,140}\\.(jpg|jpeg|png|webp|gif)$')
        && request.resource.size <= 5 * 1024 * 1024
        && request.resource.contentType.matches('image/(jpeg|png|webp|gif)');
    }

    match /families/{familyId}/people/{personId}/{fileName} {
      allow read: if isFamilyMember(familyId);
      allow create, update: if signedIn()
        && isFamilyEditor(familyId)
        && isSafeProfileImage(fileName);
      allow delete: if isFamilyEditor(familyId);
    }

    match /families/{familyId}/people/{personId}/uploads/{userId}/{fileName} {
      allow read: if signedIn();
      allow create, update: if signedIn()
        && request.auth.uid == userId
        && isSafeProfileImage(fileName);
      allow delete: if signedIn()
        && request.auth.uid == userId;
    }
  }
}
