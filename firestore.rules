rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function familyDoc(familyId) {
      return get(/databases/$(database)/documents/families/$(familyId));
    }

    function isFamilyMemberData(data) {
      return signedIn()
        && (
          data.ownerId == request.auth.uid
          || (
            data.memberIds is list
            && request.auth.uid in data.memberIds
          )
        );
    }

    function isFamilyMember(familyId) {
      return isFamilyMemberData(familyDoc(familyId).data);
    }

    function isFamilyOwner(familyId) {
      return signedIn() && familyDoc(familyId).data.ownerId == request.auth.uid;
    }

    function isFamilyEditor(familyId) {
      return signedIn()
        && (
          familyDoc(familyId).data.ownerId == request.auth.uid
          || familyDoc(familyId).data.memberRoles[request.auth.uid] == 'editor'
        );
    }

    function isLeavingFamily() {
      return signedIn()
        && resource.data.memberIds is list
        && request.auth.uid in resource.data.memberIds
        && !(request.auth.uid in request.resource.data.memberIds)
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['memberIds', 'memberRoles']);
    }

    function isJoiningFamily() {
      return signedIn()
        && resource.data.memberIds is list
        && request.resource.data.memberIds is list
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['memberIds'])
        && !(request.auth.uid in resource.data.memberIds)
        && request.auth.uid in request.resource.data.memberIds
        && request.resource.data.memberIds.size() == resource.data.memberIds.size() + 1
        && request.resource.data.memberIds.hasAll(resource.data.memberIds);
    }

    match /families/{familyId} {
      allow create: if signedIn()
        && request.resource.data.ownerId == request.auth.uid
        && request.auth.uid in request.resource.data.memberIds
        && request.resource.data.memberRoles[request.auth.uid] == 'owner';

      allow read: if isFamilyMemberData(resource.data);
      allow update: if isFamilyOwner(familyId)
        || isLeavingFamily()
        || isJoiningFamily();
      allow delete: if isFamilyOwner(familyId);
    }

    match /joinCodes/{joinCode} {
      allow create: if signedIn()
        && request.resource.data.familyId is string
        && isFamilyOwner(request.resource.data.familyId);

      allow read: if signedIn();
      allow update, delete: if signedIn()
        && resource.data.familyId is string
        && isFamilyOwner(resource.data.familyId);
    }

    match /users/{userId} {
      allow read: if signedIn();
      allow create, update: if signedIn() && request.auth.uid == userId;
      allow delete: if false;
    }

    match /people/{personId} {
      allow create: if signedIn()
        && request.resource.data.familyId is string
        && isFamilyEditor(request.resource.data.familyId);

      allow read: if signedIn()
        && resource.data.familyId is string
        && isFamilyMember(resource.data.familyId);

      allow update, delete: if signedIn()
        && resource.data.familyId is string
        && isFamilyEditor(resource.data.familyId);
    }

    // Keep the example tree read-only once strict rules are deployed.
    match /example/{personId} {
      allow read: if true;
      allow write: if false;
    }
  }
}
