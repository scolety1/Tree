rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function familyDoc(familyId) {
      return get(/databases/$(database)/documents/families/$(familyId));
    }

    function isFamilyMember(familyId) {
      return signedIn()
        && (
          familyDoc(familyId).data.ownerId == request.auth.uid
          || (
            familyDoc(familyId).data.memberIds is list
            && request.auth.uid in familyDoc(familyId).data.memberIds
          )
        );
    }

    function isFamilyOwner(familyId) {
      return signedIn() && familyDoc(familyId).data.ownerId == request.auth.uid;
    }

    function isLeavingFamily() {
      return signedIn()
        && resource.data.memberIds is list
        && request.auth.uid in resource.data.memberIds
        && !(request.auth.uid in request.resource.data.memberIds)
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['memberIds', 'memberRoles']);
    }

    match /families/{familyId} {
      allow create: if signedIn()
        && request.resource.data.ownerId == request.auth.uid
        && request.auth.uid in request.resource.data.memberIds;

      allow read: if isFamilyMember(familyId);
      allow update: if isFamilyOwner(familyId)
        || isLeavingFamily()
        || (
          signedIn()
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['memberIds', 'memberRoles'])
          && request.auth.uid in request.resource.data.memberIds
        );
      allow delete: if isFamilyOwner(familyId);
    }

    match /joinCodes/{joinCode} {
      allow create: if signedIn()
        && request.resource.data.familyId is string
        && isFamilyOwner(request.resource.data.familyId);

      allow read: if signedIn();
      allow update, delete: if signedIn()
        && resource.data.familyId is string
        && isFamilyOwner(resource.data.familyId);
    }

    match /users/{userId} {
      allow read: if signedIn();
      allow create, update: if signedIn() && request.auth.uid == userId;
      allow delete: if false;
    }

    match /people/{personId} {
      allow create: if signedIn()
        && request.resource.data.familyId is string
        && isFamilyMember(request.resource.data.familyId);

      allow read: if signedIn()
        && resource.data.familyId is string
        && isFamilyMember(resource.data.familyId);

      allow update, delete: if signedIn()
        && resource.data.familyId is string
        && isFamilyMember(resource.data.familyId);
    }

    // Keep the example tree read-only once strict rules are deployed.
    match /example/{personId} {
      allow read: if true;
      allow write: if false;
    }
  }
}
