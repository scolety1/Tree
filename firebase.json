{
  "hosting": {
    "public": ".",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**",
      "api/**",
      "scripts/**",
      "tmp_*/**",
      "*.md",
      "firestore.rules",
      "firestore.indexes.json",
      "storage.rules",
      "package.json",
      "package-lock.json",
      "vercel.json"
    ],
    "rewrites": [
      {
        "source": "/",
        "destination": "/html/home_page.html"
      },
      {
        "source": "/home",
        "destination": "/html/home_page.html"
      },
      {
        "source": "/tree",
        "destination": "/html/tree_page.html"
      },
      {
        "source": "/p/tree",
        "destination": "/html/tree_page.html"
      },
      {
        "source": "/tree-spike",
        "destination": "/html/family_chart_spike.html"
      },
      {
        "source": "/search",
        "destination": "/html/search_page.html"
      },
      {
        "source": "/p/search",
        "destination": "/html/search_page.html"
      },
      {
        "source": "/profile",
        "destination": "/html/profile.html"
      },
      {
        "source": "/p/profile",
        "destination": "/html/profile.html"
      },
      {
        "source": "/signin",
        "destination": "/html/signin.html"
      },
      {
        "source": "/p/signin",
        "destination": "/html/signin.html"
      },
      {
        "source": "/account",
        "destination": "/html/dashboard.html"
      },
      {
        "source": "/p/account",
        "destination": "/html/dashboard.html"
      },
      {
        "source": "/dashboard",
        "destination": "/html/dashboard.html"
      }
    ],
    "headers": [
      {
        "source": "**",
        "headers": [
          {
            "key": "X-Content-Type-Options",
            "value": "nosniff"
          },
          {
            "key": "X-Frame-Options",
            "value": "SAMEORIGIN"
          },
          {
            "key": "X-XSS-Protection",
            "value": "1; mode=block"
          },
          {
            "key": "Content-Security-Policy-Report-Only",
            "value": "default-src 'self'; base-uri 'self'; object-src 'none'; frame-ancestors 'self'; script-src 'self' https://www.gstatic.com https://cdn.jsdelivr.net; style-src 'self' 'unsafe-inline' https://cdn.jsdelivr.net; img-src 'self' data: blob: https:; connect-src 'self' https://*.googleapis.com https://*.firebaseio.com https://*.firebaseapp.com https://*.firebasestorage.app wss://*.firebaseio.com; frame-src 'self'; font-src 'self' data:; form-action 'self'"
          },
          {
            "key": "Cache-Control",
            "value": "no-cache, no-store, must-revalidate"
          },
          {
            "key": "Pragma",
            "value": "no-cache"
          },
          {
            "key": "Expires",
            "value": "0"
          }
        ]
      }
    ]
  },
  "firestore": {
    "rules": "firestore.rules",
    "indexes": "firestore.indexes.json"
  },
  "storage": {
    "rules": "storage.rules"
  }
}
